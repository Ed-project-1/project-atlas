# ─────────────────────────────────────────────────────────────
# Project Atlas — Example environment variables
#
# Copy this file to .env and fill in real values
# cp .env.example .env
# Never put real credentials in this file
# ─────────────────────────────────────────────────────────────

# MinIO — local Azure Data Lake Storage
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=your_access_key_here
MINIO_SECRET_KEY=your_secret_key_here

# Bucket names
BRONZE_BUCKET=bronze
SILVER_BUCKET=silver
GOLD_BUCKET=gold
QUARANTINE_BUCKET=quarantine

# MongoDB — local Cosmos DB
MONGODB_URI=mongodb://username:password@mongodb:27017
MONGODB_DB=atlas_pipeline

# PostgreSQL — local Synapse Analytics
POSTGRES_URI=postgresql://username:password@postgres:5432/atlas_gold

# Pipeline settings
PIPELINE_NAME=atlas-bronze-ingestion
